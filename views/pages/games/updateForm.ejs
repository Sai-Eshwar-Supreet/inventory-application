<!DOCTYPE html>
<html lang="en">
    <%- include('../../partials/head') %>
    <body>
        <%- include('../../partials/header') %>
        <%- include('../../partials/errors') %>
        <h2>Update Game</h2>
        <form action="/games/<%= game.id %>/edit" method="POST">
            <label for="name">Name:</label>
            <input type="text" id="name" name="name" value="<%= game.name %>" required>
            <label for="description">Description:</label>
            <input type="text" id="description" name="description" value="<%= game.description %>" required>

            <div>
                <h3>Genres</h3>
                <% genres.forEach(genre => { %>
                    <label>
                        <input type="checkbox" name="genres" value="<%= genre.id %>" <%= game.genres?.some(g => g.id === genre.id) ? 'checked' : '' %>>
                        <%= genre.name %>
                    </label>
                <% }) %>
            </div>
            <div>
                <h3>Developers</h3>
                <% developers.forEach(developer => { %>
                    <label>
                        <input type="checkbox" name="developers" value="<%= developer.id %>" <%= game.developers?.some(d => d.id === developer.id) ? 'checked' : '' %>>
                        <%= developer.name %>
                    </label>
                <% }) %>
            </div>
            
            <button type="submit">Update Game</button>
        </form>

        <%- include('../../partials/footer') %>
    </body>
</html>