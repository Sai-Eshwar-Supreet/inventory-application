<!DOCTYPE html>
<html lang="en">
    <%- include('../../partials/head') %>
    <body>
        <%- include('../../partials/header') %>

        <div class="page-header">
            <%- include('../../partials/headers/page-header', 
                {
                    heading: 'Update Release'
                }
            )%>
        </div>

        <main class="content">
            <%- include('../../partials/errors') %>
            <form class="form" action="/games/releases/<%= release.id %>/edit " method="POST">
                <%- include('../../partials/inputs/select-input',
                    {
                        name: 'game',
                        label: 'Game',
                        values: games,
                        selected: release.gameId,
                        required: true,
                    }
                )%>
                <%- include('../../partials/inputs/select-input',
                    {
                        name: 'edition',
                        label: 'Edition',
                        values: editions,
                        selected: release.editionId,
                        required: true,
                    }
                )%>
                <%- include('../../partials/inputs/select-input',
                    {
                        name: 'platform',
                        label: 'Platform',
                        values: platforms,
                        selected: release.platformId,
                        required: true,
                    }
                )%>
                <%- include('../../partials/inputs/select-input',
                    {
                        name: 'publisher',
                        label: 'Publisher',
                        values: publishers,
                        selected: release.publisherId,
                        required: true,
                    }
                )%>
                <%- include('../../partials/inputs/select-input',
                    {
                        name: 'region',
                        label: 'Region',
                        values: regions,
                        selected: release.regionId,
                        required: true,
                    }
                )%>
                <%- include('../../partials/inputs/date-input',
                    {
                        name: 'releaseDate',
                        label: 'Release Date',
                        value: release.releaseDate.toISOString().split('T')[0],

                    }
                )%>
                <%- include('../../partials/inputs/number-input',
                    {
                        name: 'price',
                        label: 'Price',
                        step: 0.01,
                        value: release.price
                    }
                )%>
                <%- include('../../partials/inputs/url-input',
                    {
                        name: 'coverImagePath',
                        label: 'Cover Image Path',
                        value: release.coverImagePath
                    }
                )%>
                <%- include('../../partials/buttons/submit-button', 
                    {
                        label : 'Update Game Release'
                    }
                )%>
            </form>
        </main>

        <%- include('../../partials/footer') %>
    </body>
</html>