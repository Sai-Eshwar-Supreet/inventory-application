<!DOCTYPE html>
<html lang="en">
    <%- include('partials/head') %>
    <body>
        <%- include('partials/header') %>

        <div class="page-header">
            <%- include('./partials/headers/page-header', 
                {
                    heading: 'Home'
                }
            )%>
        </div>
        <form class="search-bar" action="/search" method="POST">
            <input type="search" value="<%= locals.searchTerm %>" name="searchTerm" />
            <%- include('./partials/buttons/submit-button', {label: 'Search'}) %>
        </form>
        <main class="content">
            <%- include('./partials/cards/release-card', {releases}) %>
        </main>
        <%- include('partials/footer') %>
    </body>
</html>